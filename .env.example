# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your Telegram user ID (for auth — send /start to @userinfobot to get it)
TELEGRAM_ALLOWED_USER_ID=123456789

# Claude model to use (used by Claude CLI)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Daily prompt time (24h format, defaults to 18:00)
DAILY_PROMPT_HOUR=18
DAILY_PROMPT_MINUTE=0
# Minutes after prompt to send reminder (default: 30)
DAILY_REMINDER_AFTER=30

# Timezone for scheduling (IANA format)
TZ=America/Sao_Paulo
